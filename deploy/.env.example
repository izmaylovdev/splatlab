# SplatLab local Docker config. Copy to deploy/.env and edit as needed:
#   cp deploy/.env.example deploy/.env
# docker compose reads deploy/.env automatically (this file lives in deploy/).

# ---- dev S3 (in-compose MinIO) ---------------------------------------------
# Credentials for the bundled MinIO. AWS_* for the app are derived from these.
MINIO_ROOT_USER=splatlab
MINIO_ROOT_PASSWORD=splatlab-secret
SPLATLAB_S3_BUCKET=splatlab
SPLATLAB_S3_REGION=us-east-1
# Endpoint the BROWSER uses for presigned artifact GETs. Keep localhost for a
# laptop; change if you expose MinIO elsewhere.
SPLATLAB_S3_PUBLIC_ENDPOINT=http://localhost:9000

# ---- Redis auth ------------------------------------------------------------
# Required. Redis (6379) is exposed to the internet through the ngrok tunnel, so
# an unauthenticated Redis would be compromised fast.
# Generate one: `LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 40`
REDIS_PASSWORD=change-me

# ---- GPU pool (only with `--profile pool`) ---------------------------------
# Auto-rents Vast.ai GPU boxes on demand and releases them when idle.
# Vast.ai API key (Account -> API). Without it the pool refuses to start.
VAST_API_KEY=
VAST_GPU_NAME=
VAST_MAX_PRICE=0.60
SPLATLAB_POOL_MAX_BOXES=3
# SAFETY: 1 = rent nothing (drain to zero). Keep ON until a rented box can reach
# this Mac (ngrok tunnels up, BOX_* filled below). Set to 0 to actually rent GPUs.
SPLATLAB_POOL_PAUSED=1

# ---- ngrok (how a rented box reaches your Mac) -----------------------------
# The Mac is behind carrier-grade NAT (no inbound), so a box can't dial in
# directly. ngrok exposes Temporal/Redis/MinIO as public TCP addresses the box
# dials OUT to. Get an authtoken at ngrok.com (Your Authtoken); the free tier
# needs credit-card verification to enable TCP, allows 3 endpoints (exactly what
# we use), and caps transfer at 1 GB/mo — fine for a small first run.
NGROK_AUTHTOKEN=
# BOX_* below are the box-facing addresses the pool forwards to each rented box.
# DON'T edit by hand — `bash deploy/ngrok_up.sh` starts the tunnels and fills
# these in (free-tier addresses change each ngrok session, so re-run it then).
BOX_TEMPORAL_ADDRESS=
BOX_REDIS_URL=
BOX_S3_ENDPOINT=
