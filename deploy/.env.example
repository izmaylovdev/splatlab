# SplatLab local Docker config. Copy to deploy/.env and edit as needed:
#   cp deploy/.env.example deploy/.env
# docker compose reads deploy/.env automatically (this file lives in deploy/).

# ---- dev S3 (in-compose MinIO) ---------------------------------------------
# Credentials for the bundled MinIO. AWS_* for the app are derived from these.
MINIO_ROOT_USER=splatlab
MINIO_ROOT_PASSWORD=splatlab-secret
SPLATLAB_S3_BUCKET=splatlab
SPLATLAB_S3_REGION=us-east-1
# Endpoint the BROWSER uses for presigned artifact GETs. Keep localhost for a
# laptop; change if you expose MinIO elsewhere.
SPLATLAB_S3_PUBLIC_ENDPOINT=http://localhost:9000

# ---- Redis auth ------------------------------------------------------------
# Required. Especially important in static-IP mode, where Redis (6379) is
# exposed on the public internet — an unauthenticated Redis is compromised fast.
# Generate one: `LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 40`
REDIS_PASSWORD=change-me

# ---- GPU pool (only with `--profile pool`) ---------------------------------
# Auto-rents Vast.ai GPU boxes on demand and releases them when idle.
# Vast.ai API key (Account -> API). Without it the pool refuses to start.
VAST_API_KEY=
VAST_GPU_NAME=
VAST_MAX_PRICE=0.60
SPLATLAB_POOL_MAX_BOXES=3
# SAFETY: 1 = rent nothing (drain to zero). Keep ON until a rented box can reach
# this Mac (ports forwarded, or Tailscale). Set to 0 to actually rent GPUs.
SPLATLAB_POOL_PAUSED=1

# ---- Tailscale (how a rented box reaches your Mac) -------------------------
# Your Mac's tailnet IP (run `tailscale ip -4` on the Mac after installing the
# Tailscale app and signing in). The pool forwards Temporal/Redis/MinIO on this
# host to each rented box, so they dial back into your laptop.
SPLATLAB_HOST=
# A Tailscale auth key (Admin console -> Settings -> Keys; reusable + ephemeral
# recommended). Each rented box joins the tailnet with this on boot.
TAILSCALE_AUTHKEY=
